		<ProjectReference Include="..\..\src\DeepSeek.Agents.AI\DeepSeek.Agents.AI.csproj" />
		<ProjectReference Include="..\..\src\DeepSeek.Core\DeepSeek.Core.csproj" />
	</ItemGroup>-->

</Project>
